# Copy this file to .env and fill in your values:
#   cp .env.example .env
# .env is gitignored — never commit real API keys.

# ---------------------------------------------------------------------------
# Set to "false" to use hardcoded fallback responses (no API key needed)
# ---------------------------------------------------------------------------
USE_LLM=true

# ---------------------------------------------------------------------------
# Provider: "gemini" | "openai" | "ollama"
# ---------------------------------------------------------------------------
LLM_PROVIDER=gemini

# ---------------------------------------------------------------------------
# Google Gemini (recommended — fast, free tier available)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# OpenAI (alternative cloud provider)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Ollama (local, no API key required)
# Install from https://ollama.com and run: ollama pull llama3:8b
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
